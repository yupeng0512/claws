# CLAWS — Knot Agent 配置
# ──────────────────────────────

# 共享配置
KNOT_API_BASE_URL=http://knot.woa.com
KNOT_TIMEOUT=180

# 认证方式（二选一）
# 方式 1: 个人 Token（简单，一个 token 调所有 Agent）
KNOT_API_TOKEN=your_personal_token_here
# 方式 2: 智能体 Token（需搭配 KNOT_USERNAME）
# KNOT_USERNAME=your_username

# 云工作区（所有 Agent 共用同一个 workspace）
KNOT_WORKSPACE_UUID=your_workspace_uuid_here

# ── Scout（信息侦察兵）──
KNOT_SCOUT_AGENT_ID=your_scout_agent_id
KNOT_SCOUT_AGENT_TOKEN=your_scout_token

# ── Analyst（深度分析师）──
KNOT_ANALYST_AGENT_ID=your_analyst_agent_id
KNOT_ANALYST_AGENT_TOKEN=your_analyst_token

# ── Evolve（品味进化者）──
KNOT_EVOLVE_AGENT_ID=your_evolve_agent_id
KNOT_EVOLVE_AGENT_TOKEN=your_evolve_token

# ── Reviewer（独立审查者，默认可复用 Analyst）──
KNOT_REVIEWER_AGENT_ID=your_reviewer_agent_id
KNOT_REVIEWER_AGENT_TOKEN=your_reviewer_token

# 飞书推送（群机器人 Webhook）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_hook_id

# Ops Dashboard 运维上报
OPS_DASHBOARD_URL=http://ops-dashboard:9090

# 调度
CLAWS_SENSE_INTERVAL_HOURS=4
CLAWS_TIMEZONE=Asia/Shanghai
